(
    name: "T2.8 commander color identity detects off-color cards",
    setup: (
        players: 1,
        objects: [
            (card: 28004, owner: 0, controller: 0, zone: "Command"),
            (card: 28005, owner: 0, controller: 0, zone: "Battlefield"),
        ],
    ),
    script: [
        (action: "designate_commander", object: 0, colors: ["black"]),
        (action: "set_object_color_identity", object: 1, colors: ["green"]),
        (action: "assert_commander_identity_legal", player: 0, object: 1, expected: false),
    ],
    expect: (
        zone_counts: [
            (zone: "Command", count: 1),
            (zone: "Battlefield", count: 1),
        ],
        outcome: "in_progress",
        invariants: ["zone_conservation", "hash_consistency"],
        hash_determinism: true,
    ),
)
