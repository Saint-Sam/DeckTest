(
    name: "T2.8 commander color identity validation accepts in-identity cards",
    setup: (
        players: 1,
        objects: [
            (card: 28002, owner: 0, controller: 0, zone: "Command"),
            (card: 28003, owner: 0, controller: 0, zone: "Battlefield"),
        ],
    ),
    script: [
        (action: "designate_commander", object: 0, colors: ["white", "blue"]),
        (action: "set_object_color_identity", object: 1, colors: ["white"]),
        (action: "assert_commander_identity_legal", player: 0, object: 1, expected: true),
        (action: "validate_commander_color_identity", player: 0, objects: [1]),
    ],
    expect: (
        zone_counts: [
            (zone: "Command", count: 1),
            (zone: "Battlefield", count: 1),
        ],
        outcome: "in_progress",
        invariants: ["zone_conservation", "hash_consistency"],
        hash_determinism: true,
    ),
)
