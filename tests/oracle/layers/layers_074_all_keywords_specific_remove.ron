(
    name: "layers 074 all keywords specific remove",
    setup: (players: 2, objects: [(card: 63091, owner: 0, controller: 0, zone: "Battlefield"), (card: 63092, owner: 0, controller: 0, zone: "Battlefield")]),
    script: [
        (action: "set_base_creature", object: 0, power: 2, toughness: 2, keywords: ["flying"]),
        (action: "set_base_creature", object: 1, power: 2, toughness: 2, keywords: ["flying"]),
        (action: "register_continuous_effect", controller: 0, all_objects: true, operation: "add_keywords", keywords: ["trample"], timestamp: 1),
        (action: "register_continuous_effect", controller: 0, target_object: 1, operation: "remove_keywords", keywords: ["flying", "trample"], timestamp: 2),
    ],
    expect: (characteristics: [(object: 0, keywords: ["flying", "trample"]), (object: 1, keywords: [])], outcome: "in_progress", invariants: ["zone_conservation", "hash_consistency"], hash_determinism: true),
)
