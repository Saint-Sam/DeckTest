(
    name: "layers 057 all objects change controller",
    setup: (players: 2, objects: [(card: 63067, owner: 0, controller: 0, zone: "Battlefield"), (card: 63068, owner: 0, controller: 0, zone: "Battlefield")]),
    script: [
        (action: "set_base_creature", object: 0, power: 2, toughness: 2, keywords: []),
        (action: "set_base_creature", object: 1, power: 3, toughness: 3, keywords: []),
        (action: "register_continuous_effect", controller: 1, all_objects: true, operation: "change_controller", player: 1, timestamp: 1),
    ],
    expect: (characteristics: [(object: 0, controller: 1), (object: 1, controller: 1)], outcome: "in_progress", invariants: ["zone_conservation", "hash_consistency"], hash_determinism: true),
)
