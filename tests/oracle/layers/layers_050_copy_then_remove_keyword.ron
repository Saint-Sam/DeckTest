(
    name: "layers 050 copy then remove keyword",
    setup: (players: 2, objects: [(card: 63058, owner: 0, controller: 0, zone: "Battlefield"), (card: 63059, owner: 0, controller: 0, zone: "Battlefield")]),
    script: [
        (action: "set_base_creature", object: 0, power: 2, toughness: 2, keywords: ["flying"]),
        (action: "set_base_creature", object: 1, power: 1, toughness: 1, keywords: []),
        (action: "register_continuous_effect", controller: 0, target_object: 1, operation: "copy_base_creature", from_object: 0, timestamp: 1),
        (action: "register_continuous_effect", controller: 0, target_object: 1, operation: "remove_keywords", keywords: ["flying"], timestamp: 2),
    ],
    expect: (characteristics: [(object: 1, power: 2, toughness: 2, keywords: [])], outcome: "in_progress", invariants: ["zone_conservation", "hash_consistency"], hash_determinism: true),
)
