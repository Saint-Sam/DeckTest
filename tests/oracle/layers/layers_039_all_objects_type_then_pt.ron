    expect: (characteristics: [(object: 0, is_creature: true, power: 2, toughness: 2), (object: 1, is_creature: true, power: 2, toughness: 2)], outcome: "in_progress", invariants: ["zone_conservation", "hash_consistency"], hash_determinism: true),
)
