(
    name: "layers 039 all objects type then pt",
    setup: (players: 2, objects: [(card: 63044, owner: 0, controller: 0, zone: "Battlefield"), (card: 63045, owner: 1, controller: 1, zone: "Battlefield")]),
    script: [
        (action: "register_continuous_effect", controller: 0, all_objects: true, operation: "add_types", types: ["creature"], timestamp: 1),
