(
    name: "T2.7 token copy has copied values and ceases off battlefield",
    setup: (
        players: 1,
        objects: [
            (card: 27008, owner: 0, controller: 0, zone: "Battlefield"),
        ],
    ),
    script: [
        (action: "set_base_creature", object: 0, power: 4, toughness: 2, keywords: ["trample"]),
        (action: "create_permanent_copy", source: 0, owner: 0, controller: 0, token: true),
        (action: "assert_object_flags", object: 1, token: true, copy: true, copy_source: 0),
        (action: "assert_characteristics", object: 1, power: 4, toughness: 2, keywords: ["trample"]),
        (action: "move_object", object: 1, zone: "Graveyard", player: 0),
        (action: "check_state_based_actions"),
        (action: "assert_object_zone", object: 1, zone: "Ceased"),
    ],
    expect: (
        zone_counts: [
            (zone: "Battlefield", count: 1),
            (zone: "Graveyard", player: 0, count: 0),
            (zone: "Ceased", count: 1),
        ],
        outcome: "in_progress",
        invariants: ["zone_conservation", "hash_consistency"],
        hash_determinism: true,
    ),
)
