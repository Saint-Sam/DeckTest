(
    name: "T2.7 token moved off battlefield ceases to exist",
    setup: (
        players: 1,
    ),
    script: [
        (action: "create_token", card: 27005, owner: 0, controller: 0, power: 1, toughness: 1, keywords: []),
        (action: "assert_object_flags", object: 0, token: true, copy: false),
        (action: "move_object", object: 0, zone: "Graveyard", player: 0),
        (action: "check_state_based_actions"),
        (action: "assert_object_zone", object: 0, zone: "Ceased"),
    ],
    expect: (
        zone_counts: [
            (zone: "Battlefield", count: 0),
            (zone: "Graveyard", player: 0, count: 0),
            (zone: "Ceased", count: 1),
        ],
        outcome: "in_progress",
        invariants: ["zone_conservation", "hash_consistency"],
        hash_determinism: true,
    ),
)
