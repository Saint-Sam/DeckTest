(
    name: "T2.3 replacement order changes final combat damage",
    setup: (
        players: 2,
        libraries: [
            (player: 0, cards: [62001, 62002]),
        ],
        objects: [
            (card: 62010, owner: 0, controller: 0, zone: "Battlefield"),
        ],
    ),
    script: [
        (action: "set_base_creature", object: 0, power: 3, toughness: 3, keywords: []),
        (action: "register_damage_replacement", controller: 1, target_player: 1, combat_only: true, operation: "double"),
        (action: "register_damage_replacement", controller: 1, target_player: 1, combat_only: true, operation: "prevent", amount: 2),
        (action: "set_replacement_order", chooser: 1, order: [1, 0]),
        (action: "start_turn", player: 0),
        (action: "advance_step"),
        (action: "advance_step"),
        (action: "advance_step"),
        (action: "advance_step"),
        (action: "advance_step"),
        (action: "declare_attackers", player: 0, attacks: [(attacker: 0, defender: 1)]),
        (action: "advance_step"),
        (action: "declare_blockers", player: 1, blocks: []),
        (action: "advance_step"),
        (action: "assign_combat_damage", assignments: [(source: 0, assignments: [(player: 1, amount: 3)])]),
    ],
    expect: (
        zone_counts: [
            (zone: "Battlefield", count: 1),
        ],
        players: [
            (player: 0, life: 20),
            (player: 1, life: 18),
        ],
        outcome: "in_progress",
        invariants: [
            "zone_conservation",
            "life_poison_sanity",
            "hash_consistency",
        ],
        hash_determinism: true,
    ),
)
