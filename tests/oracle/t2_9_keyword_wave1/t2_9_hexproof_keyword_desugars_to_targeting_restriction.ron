(
    name: "T2.9 hexproof keyword path desugars to targeting restriction",
    setup: (
        players: 2,
        objects: [
            (card: 29041, owner: 0, controller: 0, zone: "Hand", player: 0),
            (card: 29042, owner: 1, controller: 1, zone: "Battlefield"),
        ],
    ),
    script: [
        (action: "set_base_creature", object: 1, power: 2, toughness: 2, keywords: []),
        (action: "register_restriction", controller: 1, subject_object: 1, effect: "hexproof"),
        (
            action: "assert_can_target",
            player: 0,
            source_object: 0,
            requirement: (kind: "permanent", controller: "opponent", required_types: ["creature"]),
            target_object: 1,
            expected: false,
        ),
    ],
    expect: (
        zone_counts: [
            (zone: "Hand", player: 0, count: 1),
            (zone: "Battlefield", count: 1),
        ],
        outcome: "in_progress",
        invariants: ["zone_conservation", "hash_consistency"],
        hash_determinism: true,
    ),
)
