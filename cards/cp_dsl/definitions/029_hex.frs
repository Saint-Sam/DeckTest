// CP-DSL stratum: targeting_restrictions
card "Hex" {
  id: "89457fa8-b0e2-4277-b6a9-c6601c59b46d"
  layout: normal
  status: verified_playable
  face "Hex" {
    cost: "{4}{B}{B}"
    types: "Sorcery"
    oracle: "Destroy six target creatures."
    keywords: []
    ability spell {
      effect: destroy(target(permanents(and(type_is("creature"), equals(count("chosen_targets"), 6)))))
    }
  }
}
