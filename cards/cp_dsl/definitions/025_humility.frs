// CP-DSL stratum: continuous_layers
card "Humility" {
  id: "ed7bdb3e-5c51-4547-9266-76a791e0b2b0"
  layout: normal
  status: verified_playable
  face "Humility" {
    cost: "{2}{W}{W}"
    types: "Enchantment"
    oracle: "All creatures lose all abilities and have base power and toughness 1/1."
    keywords: []
    ability static {
      effect: continuous(all(permanents(type_is("creature"))), sequence(remove_all_abilities(any()), set_pt(any(), 1, 1)))
    }
  }
}
