{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "forge://learning/v1/decision-record",
  "title": "Forge DecisionRecord v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "episode_id", "decision_index", "context", "actor_seat",
    "public_state_hash", "player_view", "known_information_mask_sha256",
    "legal_actions", "selected_action_id", "choice_latency_us", "input_method",
    "takeback_or_misclick", "confidence", "rationale_tags", "shadow_ai",
    "bounded_solver", "compute", "resulting_state_hash"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "episode_id": {"type": "string", "minLength": 1},
    "decision_index": {"type": "integer", "minimum": 0},
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "state_key", "kind", "turn", "phase", "step", "priority_seat", "stack_depth"],
      "properties": {
        "id": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
        "state_key": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
        "normalized_benchmark_key": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
        "normalized_player_view_hash": {"type": "string", "pattern": "^[0-9a-f]{16}$"},
        "normalized_legal_action_ids": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "pattern": "^[0-9a-f]{32}$"}
        },
        "benchmark_normalization_complete": {"type": "boolean"},
        "kind": {"type": "string", "minLength": 1},
        "turn": {"type": "integer", "minimum": 0},
        "phase": {"type": ["string", "null"]},
        "step": {"type": ["string", "null"]},
        "priority_seat": {"type": ["integer", "null"], "minimum": 0},
        "stack_depth": {"type": "integer", "minimum": 0}
      }
    },
    "actor_seat": {"type": "integer", "minimum": 0},
    "public_state_hash": {"type": "string", "pattern": "^[0-9a-f]{16,64}$"},
    "player_view": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "sha256", "reference"],
      "properties": {
        "schema_version": {"type": "integer", "minimum": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "reference": {"type": ["string", "null"]}
      }
    },
    "known_information_mask_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "legal_actions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "descriptor"],
        "properties": {
          "id": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
          "descriptor": {"type": "object"}
        }
      }
    },
    "selected_action_id": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
    "choice_latency_us": {"type": "integer", "minimum": 0},
    "input_method": {"enum": ["keyboard", "mouse", "touch", "controller", "ai", "replay", "unknown"]},
    "takeback_or_misclick": {"type": ["boolean", "null"]},
    "confidence": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "rationale_tags": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "shadow_ai": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["policy_id", "top_actions", "revealed_after_commitment"],
      "properties": {
        "policy_id": {"type": "string", "minLength": 1},
        "top_actions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["action_id", "value", "visits"],
            "properties": {
              "action_id": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
              "value": {"type": "integer"},
              "visits": {"type": "integer", "minimum": 0}
            }
          }
        },
        "revealed_after_commitment": {"type": "boolean"}
      }
    },
    "bounded_solver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "action_id"],
      "properties": {
        "state": {"enum": ["not_run", "not_certified", "certified_win", "certified_required_defense"]},
        "action_id": {"type": ["string", "null"], "pattern": "^[0-9a-f]{32}$"}
      }
    },
    "compute": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_id", "configured_wall_ms", "configured_cpu_ms", "actual_wall_us",
        "actual_cpu_us", "nodes", "determinizations", "legal_action_count",
        "maximum_depth", "transposition_hits", "value_gap", "visit_gap",
        "uncertainty_ppm", "memory_delta_bytes", "stop_reason", "checkpoints"
      ],
      "properties": {
        "policy_id": {"type": "string", "minLength": 1},
        "configured_wall_ms": {"type": "integer", "minimum": 0},
        "configured_cpu_ms": {"type": ["integer", "null"], "minimum": 0},
        "actual_wall_us": {"type": "integer", "minimum": 0},
        "actual_cpu_us": {"type": ["integer", "null"], "minimum": 0},
        "nodes": {"type": "integer", "minimum": 0},
        "determinizations": {"type": "integer", "minimum": 0},
        "legal_action_count": {"type": "integer", "minimum": 1},
        "maximum_depth": {"type": "integer", "minimum": 0},
        "transposition_hits": {"type": "integer", "minimum": 0},
        "value_gap": {"type": "integer"},
        "visit_gap": {"type": "integer", "minimum": 0},
        "uncertainty_ppm": {"type": "integer", "minimum": 0, "maximum": 1000000},
        "memory_delta_bytes": {"type": ["integer", "null"]},
        "stop_reason": {"type": "string", "minLength": 1},
        "checkpoints": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "determinization", "simulations", "leading_action_id",
              "leading_visit_share_ppm", "value_gap", "visit_gap",
              "ranking_stable", "uncertainty_ppm", "bounded_solver_state",
              "stop_reason"
            ],
            "properties": {
              "determinization": {"type": "integer", "minimum": 0},
              "simulations": {"type": "integer", "minimum": 0},
              "leading_action_id": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
              "leading_visit_share_ppm": {"type": "integer", "minimum": 0, "maximum": 1000000},
              "value_gap": {"type": "integer"},
              "visit_gap": {"type": "integer", "minimum": 0},
              "ranking_stable": {"type": "boolean"},
              "uncertainty_ppm": {"type": "integer", "minimum": 0, "maximum": 1000000},
              "bounded_solver_state": {"type": "string", "minLength": 1},
              "stop_reason": {"type": ["string", "null"]}
            }
          }
        }
      }
    },
    "resulting_state_hash": {"type": "string", "pattern": "^[0-9a-f]{16,64}$"}
  }
}
